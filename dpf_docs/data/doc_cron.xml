<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Optional fallback trigger: periodically checks for generations that
             are waiting for screenshots and (re)notifies the worker queue.
             Disabled by default; enable it if you do not use an external
             webhook / queue_job to drive the Playwright worker. -->
        <record id="cron_dispatch_worker" model="ir.cron">
            <field name="name">Auto Doc: dispatch pending screenshot jobs</field>
            <field name="model_id" ref="model_doc_generation"/>
            <field name="state">code</field>
            <field name="code">model._cron_dispatch_pending()</field>
            <field name="interval_number">10</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="False"/>
        </record>

    </data>
</odoo>
