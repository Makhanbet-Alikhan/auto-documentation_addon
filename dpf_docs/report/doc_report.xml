<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        User-manual style PDF (QWeb / wkhtmltopdf).

        Structure follows the standard Odoo report pattern so the body actually
        renders: a main template loops over ``docs`` and calls the per-record
        document template, which wraps its content in web.external_layout and a
        <div class="page"> (wkhtmltopdf only renders body content placed inside
        a .page element).

        Cyrillic: wkhtmltopdf defaults to Latin-1 without a charset declaration,
        turning Russian text into mojibake ("Ð¡Ð¸ÑÑ‚ÐµÐ¼Ð°"). We declare UTF-8 and
        use DejaVu Sans, which ships with the Odoo Docker image and has full
        Cyrillic coverage (Times New Roman is absent there).
    -->

    <!-- Reusable: render a multi-line text field as <ul> bullets. -->
    <template id="doc_bullets">
        <ul t-if="text">
            <t t-foreach="text.split('\n')" t-as="line">
                <li t-if="line.strip()" t-esc="line.strip()"/>
            </t>
        </ul>
    </template>

    <!-- Per-record document template. -->
    <template id="report_doc_module_document">
        <t t-set="primary" t-value="doc"/>
        <t t-set="system_name"
           t-value="primary.system_name or ('Система &quot;%s&quot;' % (primary.name or 'Odoo'))"/>
        <t t-set="platform" t-value="primary.platform_version or 'Odoo 19'"/>

        <t t-call="web.external_layout">
            <div class="page dpf-manual">
                <meta charset="utf-8"/>
                <style>
                    .dpf-manual { font-family: 'DejaVu Sans', sans-serif;
                        font-size: 12pt; color: #000; line-height: 1.45; }
                    .dpf-cover { text-align: center; padding-top: 220px; }
                    .dpf-cover .sys { font-size: 18pt; }
                    .dpf-cover .sub { font-size: 16pt; margin-top: 22px; }
                    .dpf-cover .dev { font-size: 12pt; margin-top: 80px; }
                    .dpf-cover .city { font-size: 12pt; margin-top: 140px; }
                    .dpf-toc-title { text-align: center; font-weight: bold;
                        font-size: 14pt; margin-bottom: 24px; }
                    .dpf-toc { list-style: none; padding-left: 0; }
                    .dpf-toc li { margin: 4px 0; }
                    .dpf-toc .lvl1 { font-weight: bold; }
                    .dpf-toc .lvl2 { padding-left: 24px; }
                    .dpf-toc .lvl3 { padding-left: 48px; }
                    .dpf-manual h1 { font-size: 14pt; font-weight: bold; margin-top: 18px; }
                    .dpf-manual h2 { font-size: 12pt; font-weight: bold; margin-top: 14px; }
                    .dpf-manual h3 { font-size: 12pt; font-weight: bold; margin-top: 12px; }
                    .dpf-func { margin-top: 16px; }
                    .dpf-func .ftitle { font-weight: bold; }
                    .dpf-func .label { font-weight: bold; }
                    .dpf-func .req { color: #C00000; }
                    .dpf-func ol { margin: 6px 0 6px 22px; }
                    .dpf-fig { text-align: center; margin: 10px 0; page-break-inside: avoid; }
                    .dpf-fig img { max-width: 90%; border: 1px solid #ddd; }
                    .dpf-fig .cap { font-size: 10pt; margin-top: 4px; }
                    .page-break { page-break-after: always; }
                </style>

                <!-- ============ Cover page ============ -->
                <div class="dpf-cover">
                    <div class="sys" t-esc="system_name"/>
                    <div class="sys">на базе платформы "<t t-esc="platform"/>"</div>
                    <div class="sub">Руководство пользователя</div>
                    <div class="sub">Версия <t t-esc="primary.manual_version or '1.0'"/></div>
                    <div class="dev" t-if="primary.developer">
                        Разработчик: <t t-esc="primary.developer"/>
                    </div>
                    <div class="city" t-if="primary.city_year" t-esc="primary.city_year"/>
                </div>
                <div class="page-break"/>

                <!-- ============ ОГЛАВЛЕНИЕ ============ -->
                <div class="dpf-toc-title">ОГЛАВЛЕНИЕ</div>
                <ul class="dpf-toc">
                    <li class="lvl1">1. Введение</li>
                    <li class="lvl2">1.1. Описание категории пользователей</li>
                    <li class="lvl2">1.2. Область применения</li>
                    <li class="lvl2">1.3. Назначение документа</li>
                    <li class="lvl2">1.4. Соглашения</li>
                    <li class="lvl3">1.4.1. Стилистические соглашения</li>
                    <li class="lvl1">2. Содержание документа</li>
                    <li class="lvl2">2.1. Назначение</li>
                    <li class="lvl2">2.2. Материалы</li>
                    <li class="lvl2">2.3. Подготовка</li>
                    <li class="lvl1">3. Список функций</li>
                    <li class="lvl1">4. Литература</li>
                    <li class="lvl1">5. Словарь</li>
                </ul>
                <div class="page-break"/>

                <!-- ============ 1. Введение ============ -->
                <h1>1. Введение</h1>
                <h2>1.1. Описание категории пользователей</h2>
                <t t-call="dpf_docs.doc_bullets">
                    <t t-set="text" t-value="primary.intro_user_categories"/>
                </t>
                <h2>1.2. Область применения</h2>
                <t t-call="dpf_docs.doc_bullets">
                    <t t-set="text" t-value="primary.intro_scope"/>
                </t>
                <h2>1.3. Назначение документа</h2>
                <p t-if="primary.intro_purpose" style="white-space: pre-wrap;"
                   t-esc="primary.intro_purpose"/>
                <h2>1.4. Соглашения</h2>
                <h3>1.4.1. Стилистические соглашения</h3>
                <t t-call="dpf_docs.doc_bullets">
                    <t t-set="text" t-value="primary.intro_conventions"/>
                </t>

                <!-- ============ 2. Содержание документа ============ -->
                <h1>2. Содержание документа</h1>
                <h2>2.1. Назначение</h2>
                <p t-if="primary.content_purpose" style="white-space: pre-wrap;"
                   t-esc="primary.content_purpose"/>
                <h2>2.2. Материалы</h2>
                <t t-call="dpf_docs.doc_bullets">
                    <t t-set="text" t-value="primary.content_materials"/>
                </t>
                <h2>2.3. Подготовка</h2>
                <t t-call="dpf_docs.doc_bullets">
                    <t t-set="text" t-value="primary.content_preparation"/>
                </t>
                <div class="page-break"/>

                <!-- ============ 3. Список функций ============ -->
                <h1>3. Список функций</h1>
                <t t-set="figure" t-value="0"/>
                <p t-if="not primary.function_ids">Функции для данного модуля не сформированы.</p>
                <t t-foreach="primary.function_ids" t-as="func">
                    <div class="dpf-func">
                        <div class="ftitle">Функция <t t-esc="func.number"/>:
                            <t t-esc="func.name"/>.</div>
                        <p t-if="func.description">
                            <span class="label">Описание:</span>
                            <t t-esc="func.description"/></p>
                        <p t-if="func.requirements">
                            <span class="label">Требования:</span>
                            <span class="req" t-esc="func.requirements"/></p>
                        <t t-if="func.steps and func.steps.strip()">
                            <p><span class="label">Порядок выполнения:</span></p>
                            <ol>
                                <t t-foreach="func.steps.split('\n')" t-as="step">
                                    <li t-if="step.strip()" t-esc="step.strip()"/>
                                </t>
                            </ol>
                        </t>
                        <t t-if="func.screenshot">
                            <t t-set="figure" t-value="figure + 1"/>
                            <div class="dpf-fig">
                                <img t-att-src="'data:image/png;base64,%s' % to_text(func.screenshot)"/>
                                <div class="cap">Рис.<t t-esc="figure"/>
                                    <t t-esc="func.screenshot_caption or func.name or ''"/></div>
                            </div>
                        </t>
                        <p t-if="func.result">
                            <span class="label">Результат:</span>
                            <t t-esc="func.result"/></p>
                    </div>
                </t>
                <div class="page-break"/>

                <!-- ============ 4. Литература / 5. Словарь ============ -->
                <h1>4. Литература</h1>
                <t t-call="dpf_docs.doc_bullets">
                    <t t-set="text" t-value="primary.bibliography"/>
                </t>
                <h1>5. Словарь</h1>
                <t t-call="dpf_docs.doc_bullets">
                    <t t-set="text" t-value="primary.glossary"/>
                </t>
            </div>
        </t>
    </template>

    <!-- Main report entry point: wraps every record in html_container and
         delegates to the per-record document template above. -->
    <template id="report_doc_module">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="dpf_docs.report_doc_module_document">
                    <t t-set="doc" t-value="doc"/>
                </t>
            </t>
        </t>
    </template>

</odoo>
