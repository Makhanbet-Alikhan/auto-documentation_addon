<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_doc_module" model="ir.actions.report">
        <field name="name">Module Documentation</field>
        <field name="model">doc.module</field>
        <field name="report_type">qweb-pdf</field>
        <!-- Main template (loops records and delegates per record). -->
        <field name="report_name">dpf_docs.report_doc_module</field>
        <field name="report_file">dpf_docs.report_doc_module</field>
        <!-- Downloaded file name: "<technical_name>_module_documentation.pdf". -->
        <field name="print_report_name">
            '%s_module_documentation' % (object.technical_name or 'module')
        </field>
        <field name="binding_model_id" ref="model_doc_module"/>
        <field name="binding_type">report</field>
    </record>

</odoo>
