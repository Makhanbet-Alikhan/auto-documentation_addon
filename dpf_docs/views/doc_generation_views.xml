<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_doc_generation_form" model="ir.ui.view">
        <field name="name">doc.generation.form</field>
        <field name="model">doc.generation</field>
        <field name="arch" type="xml">
            <form string="Documentation Generation">
                <header>
                    <button name="action_collect" type="object"
                            string="1. Collect Texts" class="btn-primary"
                            invisible="state not in ('draft',)"/>
                    <button name="action_capture_screenshots" type="object"
                            string="2. Capture Screenshots" class="btn-primary"
                            invisible="state not in ('awaiting_shots',)"/>
                    <button name="action_enrich_from_tasks" type="object"
                            string="3. Enrich from Tasks"
                            invisible="state in ('draft',)"
                            help="Re-run task enrichment on all collected modules."/>
                    <button name="action_download_word" type="object"
                            string="Download Word"
                            invisible="state in ('draft',)"/>
                    <button name="action_download_pdf" type="object"
                            string="Download PDF"
                            invisible="state in ('draft',)"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="module_ids" widget="many2many_tags"
                                   options="{'no_create': True}"/>
                            <field name="module_names"
                                   placeholder="optional: e.g. sale, dpf_events"/>
                        </group>
                        <group>
                            <field name="use_llm_caption"/>
                            <field name="enrich_from_project"/>
                        </group>
                    </group>

                    <!-- Task enrichment source -->
                    <group string="Task Enrichment Source"
                           invisible="not enrich_from_project">
                        <group string="Option A: Global Snapshot Set (recommended)">
                            <field name="snapshot_set_id"
                                   options="{'no_create': True}"
                                   help="Pick a pre-downloaded global snapshot set."/>
                        </group>
                        <group string="Option B: Per-run import from Project module">
                            <!-- Step 1: type project name -->
                            <label for="project_task_project_name"
                                   string="1. Type project name"/>
                            <div class="o_field_widget">
                                <div style="display:flex;gap:6px;align-items:center;">
                                    <field name="project_task_project_name"
                                           nolabel="1"
                                           placeholder="e.g. ЦПФ Этап 2"
                                           style="flex:1;"/>
                                    <button name="action_find_project"
                                            type="object"
                                            string="🔍 Find &amp; Save Project"
                                            class="btn btn-secondary"
                                            title="Search for project by name and link it to this run"/>
                                </div>
                                <!-- Show linked project ID once saved -->
                                <div invisible="not project_task_project_id"
                                     style="margin-top:4px;color:#6c757d;font-size:12px;">
                                    ✅ Linked: <field name="project_task_project_id"
                                                     nolabel="1" readonly="1"
                                                     style="display:inline;width:60px;"/> (id)
                                </div>
                            </div>
                            <!-- Step 2: import tasks -->
                            <label string="2. Import tasks into snapshot"/>
                            <div>
                                <button name="action_reimport_project_tasks"
                                        type="object"
                                        string="⬇ Re-import from Project"
                                        class="btn btn-secondary"
                                        help="Download tasks from the linked project into per-run snapshots."/>
                                <span invisible="not project_task_project_id"
                                      style="margin-left:8px;color:#6c757d;font-size:12px;">
                                    <field name="project_snapshot_count"
                                           nolabel="1" readonly="1"
                                           style="display:inline;width:40px;"/> snapshots loaded
                                </span>
                            </div>
                        </group>

                        <div class="alert alert-info" role="alert"
                             invisible="snapshot_set_id or project_task_project_id">
                            <p>
                                <b>How to link a project (Option B):</b>
                            </p>
                            <ol style="margin:4px 0 0 16px;">
                                <li>Type the project name in the field above</li>
                                <li>Click <b>🔍 Find &amp; Save Project</b></li>
                                <li>Click <b>⬇ Re-import from Project</b></li>
                            </ol>
                            <p style="margin-top:6px;">
                                Or use <b>Option A</b>: create a reusable snapshot set at
                                <i>Tools &gt; Documentation &gt; Project Snapshots</i>
                            </p>
                        </div>
                    </group>

                    <notebook>
                        <page string="Documented Modules">
                            <field name="doc_module_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="technical_name"/>
                                    <field name="menu_count"/>
                                    <field name="captured_count"/>
                                    <field name="model_count"/>
                                </list>
                            </field>
                        </page>
                        <page string="How it works">
                            <div class="alert alert-info" role="alert">
                                <p><b>Step 1</b> — Collect Texts: collects menus, models and functions.</p>
                                <p><b>Step 2</b> — Capture Screenshots: upload or auto-capture.</p>
                                <p><b>Step 3</b> — Enrich from Tasks: reads task snapshots and creates doc.function records.</p>
                                <p><b>Step 4</b> — Download Word / PDF.</p>
                                <hr/>
                                <p><b>Expected task structure in the project:</b></p>
                                <pre style="background:#f8f8f8;padding:8px;border-radius:4px;font-size:12px;">Project (e.g. «ЦПФ Этап 2»)
└── [Main task] Module development ...
     ├── [dpf_events] Feature title 1   ← tag = module technical_name
     │    ├── Subtask 1
     │    └── Subtask 2
     └── [dpf_news] ...
          └── ...</pre>
                            </div>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_doc_generation_list" model="ir.ui.view">
        <field name="name">doc.generation.list</field>
        <field name="model">doc.generation</field>
        <field name="arch" type="xml">
            <list string="Documentation Runs">
                <field name="name"/>
                <field name="module_ids" widget="many2many_tags"/>
                <field name="snapshot_set_id"/>
                <field name="project_task_project_name"/>
                <field name="project_snapshot_count" string="Per-run Snaps"/>
                <field name="state"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <record id="action_doc_generation" model="ir.actions.act_window">
        <field name="name">Documentation Runs</field>
        <field name="res_model">doc.generation</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
