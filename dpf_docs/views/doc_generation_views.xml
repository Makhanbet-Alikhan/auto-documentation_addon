<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_doc_generation_form" model="ir.ui.view">
        <field name="name">doc.generation.form</field>
        <field name="model">doc.generation</field>
        <field name="arch" type="xml">
            <form string="Documentation Generation">
                <header>
                    <button name="action_collect" type="object"
                            string="1. Collect Texts" class="btn-primary"
                            invisible="state not in ('draft',)"/>
                    <button name="action_enrich_from_tasks" type="object"
                            string="4. Enrich from Tasks"
                            invisible="state in ('draft',)"
                            help="Re-run project.task enrichment on all collected modules."/>
                    <button name="action_capture_screenshots" type="object"
                            string="2. Capture Screenshots" class="btn-primary"
                            invisible="state not in ('awaiting_shots',)"/>
                    <button name="action_render_all" type="object"
                            string="3. Render Markdown"
                            invisible="state not in ('awaiting_shots',)"/>
                    <button name="action_print_pdf" type="object"
                            string="Print PDF"
                            invisible="state in ('draft',)"/>
                    <button name="action_download_word" type="object"
                            string="Download Word"
                            invisible="state in ('draft',)"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="module_ids" widget="many2many_tags"
                                   options="{'no_create': True}"/>
                            <field name="module_names"
                                   placeholder="optional: e.g. sale, my_addon"/>
                            <label for="project_task_project_name" string="Project for Enrichment"/>
                            <div class="o_field_widget">
                                <div style="display:flex;gap:6px;align-items:center;">
                                    <field name="project_task_project_name"
                                           nolabel="1"
                                           placeholder="e.g. ЦПФ Этап 2"
                                           help="Project name is resolved to an ID automatically."/>
                                    <button name="action_pick_project" type="object"
                                            string="📂" title="Pick project from list"
                                            class="btn btn-sm btn-secondary"
                                            help="Open project picker dialog"/>
                                </div>
                                <small class="text-muted"
                                       invisible="not project_task_project_id">
                                    ID: <field name="project_task_project_id"
                                              nolabel="1" readonly="1"
                                              style="display:inline;width:auto;"/>
                                </small>
                            </div>
                        </group>
                        <group>
                            <field name="use_llm_caption"/>
                            <field name="enrich_from_project"/>
                        </group>
                    </group>

                    <!-- Project snapshot import section —
                         visible whenever enrich_from_project is checked.
                         NOTE: the Re-import button has NO invisible guard on
                         project_task_project_id because Integer fields default to 0
                         on a new unsaved record — 0 is falsy in Python/Owl and would
                         hide the button forever on creation.  The Python method raises
                         a UserError when no project is configured. -->
                    <group string="Project Task Snapshots"
                           invisible="not enrich_from_project">
                        <div style="display:flex;align-items:center;gap:12px;padding:4px 0;">
                            <button name="action_reimport_project_tasks"
                                    type="object"
                                    string="⬇ Re-import from Project"
                                    class="btn btn-secondary"
                                    help="Download all tasks from the selected project into offline snapshots. Safe to run multiple times — previous snapshots are replaced."/>
                            <span>
                                <field name="project_snapshot_count" nolabel="1" readonly="1"/>
                                snapshots loaded
                            </span>
                        </div>
                        <div class="alert alert-info" role="alert"
                             invisible="project_task_project_id != 0">
                            <p>No project selected yet. Type a project name in the field above
                            (or use 📂 to pick one), save the record, then click
                            <b>⬇ Re-import from Project</b>.</p>
                        </div>
                    </group>

                    <notebook>
                        <page string="Documented Modules">
                            <field name="doc_module_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="technical_name"/>
                                    <field name="menu_count"/>
                                    <field name="captured_count"/>
                                    <field name="model_count"/>
                                </list>
                            </field>
                        </page>
                        <page string="How it works">
                            <div class="alert alert-info" role="alert">
                                <p><b>Step 1</b> — Collect Texts: collects menus, models and functions.</p>
                                <p><b>Step 2</b> — Capture Screenshots: upload screenshots manually.</p>
                                <p><b>Step 3</b> — Render Markdown / Print PDF / Download Word.</p>
                                <p><b>Step 4 — Enrich from Tasks</b>: reads project task snapshots
                                and fills function/menu fields. Run any time after editing tasks.</p>
                                <hr/>
                                <p><b>Task structure expected in the project:</b></p>
                                <pre style="background:#f8f8f8;padding:8px;border-radius:4px;font-size:12px;">Project (e.g. «ЦПФ Этап 2»)
└── [Main task] Module development ...
     ├── [dpf_events] Feature title 1   ← tag = module technical_name
     │    ├── Subtask 1  (Description / Requirements / Steps / Result)
     │    └── Subtask 2
     └── [dpf_news] ...
          └── ...</pre>
                                <p>The enricher matches tasks whose name starts with
                                <code>[module_technical_name]</code>,
                                e.g. <code>[dpf_events]</code>, then maps their
                                subtasks to doc functions by Jaccard similarity ≥ 0.30.</p>
                            </div>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_doc_generation_list" model="ir.ui.view">
        <field name="name">doc.generation.list</field>
        <field name="model">doc.generation</field>
        <field name="arch" type="xml">
            <list string="Documentation Runs">
                <field name="name"/>
                <field name="module_ids" widget="many2many_tags"/>
                <field name="project_task_project_name"/>
                <field name="project_snapshot_count" string="Snapshots"/>
                <field name="state"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <record id="action_doc_generation" model="ir.actions.act_window">
        <field name="name">Documentation Runs</field>
        <field name="res_model">doc.generation</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
