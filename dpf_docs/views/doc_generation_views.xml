<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_doc_generation_form" model="ir.ui.view">
        <field name="name">doc.generation.form</field>
        <field name="model">doc.generation</field>
        <field name="arch" type="xml">
            <form string="Documentation Generation">
                <header>
                    <button name="action_collect" type="object"
                            string="1. Collect Texts" class="btn-primary"
                            invisible="state not in ('draft',)"/>
                    <button name="action_enrich_from_tasks" type="object"
                            string="4. Enrich from Tasks"
                            invisible="state in ('draft',)"
                            help="Re-run task enrichment on all collected modules."/>
                    <button name="action_capture_screenshots" type="object"
                            string="2. Capture Screenshots" class="btn-primary"
                            invisible="state not in ('awaiting_shots',)"/>
                    <button name="action_render_all" type="object"
                            string="3. Render Markdown"
                            invisible="state not in ('awaiting_shots',)"/>
                    <button name="action_print_pdf" type="object"
                            string="Print PDF"
                            invisible="state in ('draft',)"/>
                    <button name="action_download_word" type="object"
                            string="Download Word"
                            invisible="state in ('draft',)"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="module_ids" widget="many2many_tags"
                                   options="{'no_create': True}"/>
                            <field name="module_names"
                                   placeholder="optional: e.g. sale, dpf_events"/>
                        </group>
                        <group>
                            <field name="use_llm_caption"/>
                            <field name="enrich_from_project"/>
                        </group>
                    </group>

                    <!-- Task enrichment source -->
                    <group string="Task Enrichment Source"
                           invisible="not enrich_from_project">
                        <group>
                            <!--
                              OPTION A — Global Snapshot Set (preferred).
                              User picks a pre-downloaded set from the global pool.
                              One download shared across all generation runs.
                            -->
                            <field name="snapshot_set_id"
                                   options="{'no_create': True}"
                                   help="Pick a pre-downloaded global snapshot set. Faster — no re-download needed for each run."/>
                        </group>
                        <group>
                            <!--
                              OPTION B — Per-generation download (legacy fallback).
                              User enters project name and clicks Re-import.
                              NOTE: the Re-import button has NO invisible guard on
                              project_task_project_id — Integer defaults to 0 which
                              is falsy, hiding the button forever on new records.
                              Python raises UserError when no project is configured.
                            -->
                            <label for="project_task_project_name"
                                   string="— or — Project Name (per-run)"/>
                            <div class="o_field_widget">
                                <div style="display:flex;gap:6px;align-items:center;">
                                    <field name="project_task_project_name"
                                           nolabel="1"
                                           placeholder="e.g. ЦПФ Этап 2"/>
                                    <button name="action_pick_project" type="object"
                                            string="📂"
                                            title="Pick project from list"
                                            class="btn btn-sm btn-secondary"/>
                                </div>
                                <small class="text-muted"
                                       invisible="not project_task_project_id">
                                    ID: <field name="project_task_project_id"
                                              nolabel="1" readonly="1"
                                              style="display:inline;width:auto;"/>
                                </small>
                            </div>
                        </group>
                        <div style="display:flex;align-items:center;gap:12px;padding:4px 0;">
                            <button name="action_reimport_project_tasks"
                                    type="object"
                                    string="⬇ Re-import from Project"
                                    class="btn btn-secondary"
                                    help="Download tasks into a per-run snapshot. Use the Global Snapshot Set above to avoid re-downloading."/>
                            <span invisible="not project_task_project_id">
                                <field name="project_snapshot_count"
                                       nolabel="1" readonly="1"/>
                                per-run snapshots loaded
                            </span>
                        </div>
                        <div class="alert alert-info" role="alert"
                             invisible="snapshot_set_id or project_task_project_id">
                            <p>
                                <b>No snapshot source selected.</b> Either:
                            </p>
                            <ul>
                                <li>Select a <b>Global Snapshot Set</b> (Tools &gt; Documentation &gt; Project Snapshots), or</li>
                                <li>Type a project name above and click <b>⬇ Re-import from Project</b>.</li>
                            </ul>
                        </div>
                    </group>

                    <notebook>
                        <page string="Documented Modules">
                            <field name="doc_module_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="technical_name"/>
                                    <field name="menu_count"/>
                                    <field name="captured_count"/>
                                    <field name="model_count"/>
                                </list>
                            </field>
                        </page>
                        <page string="How it works">
                            <div class="alert alert-info" role="alert">
                                <p><b>Step 1</b> — Collect Texts: collects menus, models and functions.</p>
                                <p><b>Step 2</b> — Capture Screenshots: upload or auto-capture.</p>
                                <p><b>Step 3</b> — Render Markdown / Print PDF / Download Word.</p>
                                <p><b>Step 4 — Enrich from Tasks</b>: reads task snapshots and
                                creates doc.function records. Run any time after editing tasks.</p>
                                <hr/>
                                <p><b>Expected task structure in the project:</b></p>
                                <pre style="background:#f8f8f8;padding:8px;border-radius:4px;font-size:12px;">Project (e.g. «ЦПФ Этап 2»)
└── [Main task] Module development ...
     ├── [dpf_events] Feature title 1   ← tag = module technical_name
     │    ├── Subtask 1  (Описание / Требования / Порядок / Результат)
     │    └── Subtask 2
     └── [dpf_news] ...
          └── ...</pre>
                                <p>The enricher matches tasks whose name starts with
                                <code>[module_technical_name]</code>,
                                e.g. <code>[dpf_events]</code>, then creates
                                one <b>doc.function</b> per child subtask.
                                No name translation is required — matching is by <code>[tag]</code>
                                prefix only.</p>
                            </div>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_doc_generation_list" model="ir.ui.view">
        <field name="name">doc.generation.list</field>
        <field name="model">doc.generation</field>
        <field name="arch" type="xml">
            <list string="Documentation Runs">
                <field name="name"/>
                <field name="module_ids" widget="many2many_tags"/>
                <field name="snapshot_set_id"/>
                <field name="project_task_project_name"/>
                <field name="project_snapshot_count" string="Per-run Snaps"/>
                <field name="state"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <record id="action_doc_generation" model="ir.actions.act_window">
        <field name="name">Documentation Runs</field>
        <field name="res_model">doc.generation</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
