<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_doc_generation_form" model="ir.ui.view">
        <field name="name">doc.generation.form</field>
        <field name="model">doc.generation</field>
        <field name="arch" type="xml">
            <form string="Documentation Generation">
                <header>
                    <button name="action_collect" type="object"
                            string="1. Collect Texts" class="btn-primary"
                            invisible="state not in ('draft',)"/>
                    <button name="action_enrich_from_tasks" type="object"
                            string="4. Enrich from Tasks"
                            invisible="state in ('draft',)"
                            help="Re-run project.task enrichment on all collected modules. Use this after adding task descriptions or changing the project."/>
                    <button name="action_capture_screenshots" type="object"
                            string="2. Capture Screenshots" class="btn-primary"
                            invisible="state not in ('awaiting_shots',)"
                            help="Upload screenshots manually: open the module → Functions tab → open a function → Screenshot field."/>
                    <button name="action_render_all" type="object"
                            string="3. Render Markdown"
                            invisible="state not in ('awaiting_shots',)"/>
                    <button name="action_print_pdf" type="object"
                            string="Print PDF"
                            invisible="state in ('draft',)"/>
                    <button name="action_download_word" type="object"
                            string="Download Word"
                            invisible="state in ('draft',)"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="module_ids" widget="many2many_tags"
                                   options="{'no_create': True}"/>
                            <field name="module_names"
                                   placeholder="optional: e.g. sale, my_addon"/>
                            <field name="project_id"
                                   options="{'no_create': True}"
                                   placeholder="Необязательно: ЦПФ Этап 2"/>
                        </group>
                        <group>
                            <field name="use_llm_caption"/>
                            <field name="enrich_from_project"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Documented Modules">
                            <field name="doc_module_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="technical_name"/>
                                    <field name="menu_count"/>
                                    <field name="captured_count"/>
                                    <field name="model_count"/>
                                </list>
                            </field>
                        </page>
                        <page string="How it works">
                            <div class="alert alert-info" role="alert">
                                <p><b>Step 1</b> — Collect Texts: introspects the ORM and
                                parses Python docstrings/comments.</p>
                                <p><b>Step 2</b> — Capture Screenshots: upload screenshots
                                manually via Functions tab on each doc.module.</p>
                                <p><b>Step 3</b> — Render Markdown / Print PDF / Download Word.</p>
                                <p><b>Step 4</b> — Enrich from Tasks: re-reads project.task
                                descriptions and fills in function/menu fields. Run this
                                any time after editing tasks. Scoped to the selected
                                <i>Project</i> if set; otherwise searches all projects.</p>
                                <p><b>Task discovery order:</b></p>
                                <ol>
                                    <li>Tasks whose name starts with
                                        <code>[module_technical_name]</code>
                                        e.g. <code>[dpf_news] Описание</code></li>
                                    <li>Tasks whose name contains the module name
                                        anywhere (e.g. "Новостной портал", "dpf news")</li>
                                    <li>If a Project is selected and nothing found —
                                        all tasks from that project are used as a
                                        fallback (matched by name similarity)</li>
                                </ol>
                            </div>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_doc_generation_list" model="ir.ui.view">
        <field name="name">doc.generation.list</field>
        <field name="model">doc.generation</field>
        <field name="arch" type="xml">
            <list string="Documentation Runs">
                <field name="name"/>
                <field name="module_ids" widget="many2many_tags"/>
                <field name="project_id"/>
                <field name="state"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <record id="action_doc_generation" model="ir.actions.act_window">
        <field name="name">Documentation Runs</field>
        <field name="res_model">doc.generation</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
