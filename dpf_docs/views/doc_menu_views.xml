<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_doc_menu_list" model="ir.ui.view">
        <field name="name">doc.menu.list</field>
        <field name="model">doc.menu</field>
        <field name="arch" type="xml">
            <list string="Documented Screens">
                <field name="complete_name"/>
                <field name="res_model"/>
                <field name="view_modes"/>
                <field name="capture_state"/>
            </list>
        </field>
    </record>

    <record id="action_doc_menu" model="ir.actions.act_window">
        <field name="name">Documented Screens</field>
        <field name="res_model">doc.menu</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
