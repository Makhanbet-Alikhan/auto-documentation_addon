<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree view for snapshot records -->
    <record id="view_doc_project_task_snapshot_tree" model="ir.ui.view">
        <field name="name">doc.project.task.snapshot.tree</field>
        <field name="model">doc.project.task.snapshot</field>
        <field name="arch" type="xml">
            <list string="Task Snapshots" decoration-muted="not module_tag">
                <field name="depth" string="Depth" optional="show"/>
                <field name="module_tag" string="Module Tag"/>
                <field name="name" string="Task Name"/>
                <field name="name_clean" string="Clean Name" optional="hide"/>
                <field name="original_task_id" string="Orig. Task ID" optional="hide"/>
                <field name="generation_id" string="Generation"/>
            </list>
        </field>
    </record>

    <!-- Form view for snapshot records -->
    <record id="view_doc_project_task_snapshot_form" model="ir.ui.view">
        <field name="name">doc.project.task.snapshot.form</field>
        <field name="model">doc.project.task.snapshot</field>
        <field name="arch" type="xml">
            <form string="Task Snapshot" create="false" edit="false">
                <sheet>
                    <group>
                        <group string="Identity">
                            <field name="generation_id"/>
                            <field name="original_task_id"/>
                            <field name="original_project_id"/>
                        </group>
                        <group string="Matching">
                            <field name="module_tag"/>
                            <field name="depth"/>
                            <field name="sequence"/>
                        </group>
                    </group>
                    <group string="Content">
                        <field name="name"/>
                        <field name="name_clean"/>
                        <field name="description_plain" widget="text"/>
                    </group>
                    <group string="Hierarchy">
                        <field name="parent_snapshot_id"/>
                        <field name="child_snapshot_ids">
                            <list>
                                <field name="module_tag"/>
                                <field name="name"/>
                                <field name="depth"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_doc_project_task_snapshot" model="ir.actions.act_window">
        <field name="name">Task Snapshots</field>
        <field name="res_model">doc.project.task.snapshot</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
    </record>

</odoo>
