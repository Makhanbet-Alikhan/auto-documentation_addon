<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_doc_module_form" model="ir.ui.view">
        <field name="name">doc.module.form</field>
        <field name="model">doc.module</field>
        <field name="arch" type="xml">
            <form string="Documented Module">
                <header>
                    <button name="action_enrich_from_snapshot"
                            type="object"
                            string="⚡ Обогатить из проекта"
                            class="btn-secondary"
                            help="Заполнить описания и функции из снапшота задач проекта. Требует заполненного Project Snapshot Set в генерации."/>
                    <button name="build_functions_from_menus" type="object"
                            string="Rebuild Functions"/>
                    <button name="action_capture_screenshots" type="object"
                            string="Capture Screenshots"
                            help="Automatically take a screenshot of every documented screen and attach it under the matching function."/>
                    <button name="action_render_markdown" type="object"
                            string="Re-render Markdown"/>
                    <button name="action_print_pdf_manual" type="object"
                            string="Print PDF Manual"/>
                    <button name="action_download_word" type="object"
                            string="Download Word" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                        <h3><field name="technical_name"/></h3>
                    </div>
                    <group>
                        <field name="menu_count"/>
                        <field name="captured_count"/>
                        <field name="model_count"/>
                        <field name="function_count"/>
                    </group>
                    <field name="description" widget="text"/>
                    <notebook>
                        <page string="Manual Cover">
                            <group>
                                <field name="system_name"/>
                                <field name="platform_version"/>
                                <field name="manual_version"/>
                                <field name="developer"/>
                                <field name="city_year"/>
                            </group>
                            <group string="1. Введение">
                                <field name="intro_user_categories" widget="text"/>
                                <field name="intro_scope" widget="text"/>
                                <field name="intro_purpose" widget="text"/>
                                <field name="intro_conventions" widget="text"/>
                            </group>
                            <group string="2. Содержание документа">
                                <field name="content_purpose" widget="text"/>
                                <field name="content_materials" widget="text"/>
                                <field name="content_preparation" widget="text"/>
                            </group>
                            <group string="4-5. Литература и Словарь">
                                <field name="bibliography" widget="text"/>
                                <field name="glossary" widget="text"/>
                            </group>
                        </page>
                        <page string="Functions">
                            <field name="function_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="number"/>
                                    <field name="name"/>
                                    <field name="screenshot_source"/>
                                </list>
                                <form>
                                    <sheet>
                                        <group>
                                            <field name="number"/>
                                            <field name="name"/>
                                            <field name="doc_menu_id"/>
                                        </group>
                                        <field name="description" widget="text"
                                               placeholder="Описание..."/>
                                        <field name="requirements" widget="text"
                                               placeholder="Требования..."/>
                                        <field name="steps" widget="text"
                                               placeholder="Один шаг на строку"/>
                                        <field name="result" widget="text"
                                               placeholder="Результат..."/>
                                        <group string="Скриншот (Рис.N)">
                                            <field name="screenshot_source" readonly="1"/>
                                            <field name="screenshot_caption"
                                                   placeholder="Подпись под рисунком"/>
                                            <field name="screenshot" widget="image"
                                                   filename="screenshot_filename"
                                                   options="{'size': [400, 300]}"/>
                                            <field name="screenshot_filename"
                                                   invisible="1"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Menus">
                            <field name="menu_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="res_model"/>
                                    <field name="view_modes"/>
                                    <field name="capture_state"/>
                                </list>
                                <form>
                                    <sheet>
                                        <group>
                                            <field name="name"/>
                                            <field name="complete_name"/>
                                            <field name="res_model"/>
                                            <field name="view_modes"/>
                                            <field name="web_url"/>
                                            <field name="capture_state"/>
                                            <field name="capture_error"
                                                   invisible="capture_state != 'error'"/>
                                        </group>
                                        <field name="caption" widget="text"/>
                                        <field name="screenshot" widget="image"/>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Models">
                            <field name="model_ids">
                                <list>
                                    <field name="technical_name"/>
                                    <field name="display_name"/>
                                    <field name="field_count"/>
                                </list>
                                <form>
                                    <sheet>
                                        <group>
                                            <field name="technical_name"/>
                                            <field name="display_name"/>
                                            <field name="field_count"/>
                                        </group>
                                        <field name="description" widget="text"/>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Markdown">
                            <field name="markdown" widget="text"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_doc_module" model="ir.actions.act_window">
        <field name="name">Documented Modules</field>
        <field name="res_model">doc.module</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
