<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_doc_project_picker_wizard_form" model="ir.ui.view">
        <field name="name">doc.project.picker.wizard.form</field>
        <field name="model">doc.project.picker.wizard</field>
        <field name="arch" type="xml">
            <form string="Select Project">
                <group>
                    <field name="generation_id" invisible="1"/>
                    <field name="project_selection"
                           string="Project"
                           widget="selection"
                           help="Select a project to import tasks from"/>
                    <field name="project_display_name"
                           string="Selected"
                           invisible="not project_selection"/>
                </group>
                <footer>
                    <button name="action_confirm"
                            type="object"
                            string="Confirm"
                            class="btn-primary"
                            data-hotkey="q"/>
                    <button name="action_cancel"
                            type="object"
                            string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
