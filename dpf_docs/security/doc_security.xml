<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Odoo 19 security uses a 3-layer hierarchy:
             Category -> Privilege (res.groups.privilege) -> Group.
             Groups reference a privilege via privilege_id (category_id was
             removed from res.groups in Odoo 19). -->

        <!-- Step 1: app category. -->
        <record id="module_category_dpf_docs" model="ir.module.category">
            <field name="name">DPF Docs</field>
            <field name="description">Access to the documentation generator.</field>
            <field name="sequence">90</field>
        </record>

        <!-- Step 2: privilege (the intermediate layer, new in Odoo 19). -->
        <record id="privilege_dpf_docs" model="res.groups.privilege">
            <field name="name">Documentation</field>
            <field name="category_id" ref="module_category_dpf_docs"/>
        </record>

        <!-- Step 3: groups, linked to the privilege. -->
        <!-- A user who can launch documentation generation runs. -->
        <record id="group_doc_user" model="res.groups">
            <field name="name">Documentation User</field>
            <field name="privilege_id" ref="privilege_dpf_docs"/>
        </record>

        <!-- A manager who can also edit config and access raw API helpers. -->
        <record id="group_doc_manager" model="res.groups">
            <field name="name">Documentation Manager</field>
            <field name="privilege_id" ref="privilege_dpf_docs"/>
            <field name="implied_ids" eval="[(4, ref('group_doc_user'))]"/>
            <!-- res.groups.users was renamed to user_ids in Odoo 19. -->
            <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        </record>

    </data>
</odoo>
